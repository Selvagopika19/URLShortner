# Copy to .env and fill in values. Never commit .env with real secrets.

PORT=5000
NODE_ENV=development

# MongoDB — include DB name in path (e.g. /urlshortener)
# If you see querySrv ECONNREFUSED on Windows, use the "standard connection string" from Atlas
# (mongodb://host1:27017,host2:27017,.../?ssl=true&replicaSet=...) instead of mongodb+srv.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/urlshortener?retryWrites=true&w=majority&appName=Cluster0

# Strong random string for signing JWTs (min 32 chars in production)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Public base URL for building short links in API responses (no trailing slash)
# Example: http://localhost:5000 or https://yourdomain.com
PUBLIC_BASE_URL=http://localhost:5000
